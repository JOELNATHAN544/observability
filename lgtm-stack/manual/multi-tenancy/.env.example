# Local demo credentials for the LGTM multi-tenancy demo.
# Copy to `.env` and adjust if you like. This file is safe to commit because
# the values are only used for the loopback-only Docker Compose demo — they
# are NEVER used for any real authentication and `.env` is gitignored.
#
#     cp .env.example .env

GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# Viewer users created inside each tenant Organization.
TENANT_A_USER=alice
TENANT_A_PASSWORD=alice-demo-pass
TENANT_B_USER=bob
TENANT_B_PASSWORD=bob-demo-pass
